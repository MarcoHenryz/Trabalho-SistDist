\frametitle{compose.yaml — Serviço WordPress}
  \small
\begin{verbatim}
  wordpress:
    image: wordpress:latest
    restart: always
    ports:
      - "8080:80"
    environment:
      WORDPRESS_DB_HOST: db:3306
      WORDPRESS_DB_USER: wpuser
      WORDPRESS_DB_PASSWORD: wpsenha
      WORDPRESS_DB_NAME: wordpress
    volumes:
      - wp_data:/var/www/html
    networks:
      - wp-network
    depends_on:
      - db

volumes:
  db_data:
  wp_data:

networks:
  wp-network:
\end{verbatim}
